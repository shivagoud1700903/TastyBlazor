@page "/Category"
@inject ICategoryRepository _CategoryRepository
@inject IJSRuntime _JS
<h3>Category</h3>

<BsModal OnModalConfirmation="ConfirmDelete_Click"
         ButtonText="Delete"
         ButtonBootstrapStyle="btn btn-danger"
         Title="Are you surely want to delete this category"></BsModal>
@if(isprocessing)
{
    <div class="position-absolute w-75 h-75 d-flex flex-column align-items-center bg-white justify-content-center">
        <img src="/Images/loading.gif" alt="Loading"/>
    </div>
}
else
{
    <div class="card shadow border-0 mt-4">
        <div class="card-header bg-black bg-gradient ml-0 py-3">
            <div class="row">
                <div class="col-12 text-center">
                    <h2 class="text-white py-2">Cateogory List</h2>
                </div>
            </div>
        </div>
        <div class="card-body p-4">
            <div class="row pb-3">
                <div class="col-12 text-end">
                    <a href="category/insert" class="btn btn-lg btn-secondary " style="width:250px"><i class="bi bi-plus-square"></i>  Add New Category</a>
                </div>
            </div>
        </div>
    </div>
    <p>Category's List</p>
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <td>Name</td>
                <td></td>
            </tr>
        </thead>
        <tbody>
            @foreach(var item in Categories)
            {
                <tr>
                    <td>
                        @item.Name
                    </td>
                    <td>
                        <a href=@($"category/update/{item.Id}") class="btn btn-primary"><i class="bi bi-pencil-square"></i> Edit</a>
                        <a class="btn btn-danger" @onclick="()=>HandleDelete(item.Id)"> <i class="bi bi-trash3"></i> Delete</a>
                    </td>
                    <td>
                     
                    </td>
                   
                   
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool isprocessing { get; set; } = true;

    private int DeleteCategoryId { get; set; } = 0;

    private IEnumerable<Category> Categories { get; set; } = new List<Category>();


    // protected override async Task OnInitializedAsync()
    // {
    //     isprocessing = true;
    //     LoadParameters();
    //     await Task.Delay(2000);
    //     isprocessing = false;
    // }

    protected override async Task OnAfterRenderAsync(bool firstrender)
    {
        if (firstrender)
        {
            await LoadParameters();
            isprocessing = false;
            StateHasChanged();
        }
    }
    private async Task LoadParameters()
    {
        Categories = await _CategoryRepository.GetAllAsync();   
    }

    private void HandleDelete(int id)
    {
        DeleteCategoryId = id;
        _JS.InvokeVoidAsync("ShowConfirmationModal");
    }

    private async Task ConfirmDelete_Click(bool isConfirmed)
    {
        isprocessing = true;
        if(isConfirmed && DeleteCategoryId !=0 )
        {
            var result = await _CategoryRepository.DeleteAsync(DeleteCategoryId);
            if (result)
                await _JS.ToasterSuccess("Category Deleted Successfullay");
            else
                await _JS.ToasterError("Category not Deleted due to some error");

            await LoadParameters();
        }
        DeleteCategoryId = 0;
        _JS?.InvokeVoidAsync("HideConfirmationModal");
        isprocessing = false;
    }

}
